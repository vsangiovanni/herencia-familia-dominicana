# Plantilla para public_html/herenciard/.env en Hostinger
# Copiar a .env en el servidor y completar con valores del panel Hostinger.
# NO commitear el archivo .env real.

DB_HOST=localhost
DB_PORT=3306
DB_NAME=nombre_base_herencia
DB_USER=usuario_mysql_hostinger
DB_PASSWORD=contraseña_mysql

JWT_SECRET=generar-cadena-larga-aleatoria-minimo-32-caracteres

# Opcional: usuario administrador inicial (solo si no existe en BD)
LOCAL_ADMIN_EMAIL=admin@ejemplo.com
LOCAL_ADMIN_PASSWORD=cambiar-contraseña-segura
LOCAL_ADMIN_NAME=Administrador
